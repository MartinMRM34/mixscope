<Window x:Class="AudioChannelOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Audio Format Overlay"
        SizeToContent="WidthAndHeight"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ResizeMode="NoResize"
        ShowActivated="False" WindowStartupLocation="Manual"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <!-- Thin inline strip (NVIDIA-overlay style): one line, value groups split by dividers. -->
    <Border x:Name="RootBorder" CornerRadius="6" Padding="10,4"
            BorderThickness="1" BorderBrush="#1FFFFFFF">
        <Border.Background>
            <SolidColorBrush Color="#0C0E12" Opacity="0.82"/>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.4" Color="Black"/>
        </Border.Effect>
        <Border.ContextMenu>
            <ContextMenu Opened="Menu_Opened">
                <MenuItem x:Name="PosMenu" Header="Position">
                    <MenuItem Header="Top-left"      Tag="TopLeft"      IsCheckable="True" Click="Pos_Click"/>
                    <MenuItem Header="Top-center"    Tag="TopCenter"    IsCheckable="True" Click="Pos_Click"/>
                    <MenuItem Header="Top-right"     Tag="TopRight"     IsCheckable="True" Click="Pos_Click"/>
                    <MenuItem Header="Bottom-left"   Tag="BottomLeft"   IsCheckable="True" Click="Pos_Click"/>
                    <MenuItem Header="Bottom-center" Tag="BottomCenter" IsCheckable="True" Click="Pos_Click"/>
                    <MenuItem Header="Bottom-right"  Tag="BottomRight"  IsCheckable="True" Click="Pos_Click"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Start with Windows" x:Name="AutoStartItem" IsCheckable="True" Click="AutoStart_Click"/>
                <MenuItem Header="Open config folder" Click="OpenConfig_Click"/>
                <MenuItem Header="Exit" Click="Exit_Click"/>
            </ContextMenu>
        </Border.ContextMenu>

        <StackPanel x:Name="BarPanel" Orientation="Horizontal" VerticalAlignment="Center"/>
    </Border>
</Window>
