<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <AssemblyName>mixscope</AssemblyName>
    <RootNamespace>Mixscope</RootNamespace>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationIcon>mixscope.ico</ApplicationIcon>
    <Version>0.2.0</Version>
  </PropertyGroup>

  <!-- No external packages: VLC via HttpClient, MediaInfo via Process, JSON via System.Text.Json -->

</Project>
